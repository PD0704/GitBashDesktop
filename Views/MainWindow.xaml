<Window x:Class="GitBashDesktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GitBash Desktop"
        Height="750" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBgBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Border Grid.Column="0" Grid.RowSpan="3"
                Background="{DynamicResource SidebarBgBrush}"
                BorderBrush="{DynamicResource SidebarBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- App title + theme toggle -->
                <Grid Grid.Row="0" Margin="16,14,12,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="GITBASH DESKTOP"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            x:Name="ThemeToggleBtn"
                            Content="☀"
                            Style="{StaticResource IconButtonStyle}"
                            Click="ThemeToggleBtn_Click"
                            ToolTip="Toggle light/dark theme"/>
                </Grid>

                <!-- Nav buttons -->
                <StackPanel Grid.Row="1" Margin="0,4,0,0">
                    <Button Content="⌂  Dashboard"
                            Tag="dashboard"
                            Click="SidebarNav_Click"
                            Style="{StaticResource SidebarButtonStyle}"/>
                    <Button Content="⎇  Branches"
                            Tag="branches"
                            Click="SidebarNav_Click"
                            Style="{StaticResource SidebarButtonStyle}"/>
                    <Button Content="⏱  Commit History"
                            Tag="history"
                            Click="SidebarNav_Click"
                            Style="{StaticResource SidebarButtonStyle}"/>
                    <Button Content="⚡  Merge Conflicts"
                            Tag="conflicts"
                            Click="SidebarNav_Click"
                            Style="{StaticResource SidebarButtonStyle}"/>
                    <Button Content="⚙  Settings"
                            Tag="settings"
                            Click="SidebarNav_Click"
                            Style="{StaticResource SidebarButtonStyle}"/>
                </StackPanel>

                <!-- Account section -->
                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar circle -->
                        <Border Width="32" Height="32"
                                CornerRadius="16"
                                Background="{DynamicResource AccentBlueBrush}"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="AvatarInitials"
                                       Text="PD"
                                       Foreground="White"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Name + email -->
                        <StackPanel Grid.Column="1" Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="AccountName"
                                       Text="Prahelika Dutta"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="12"
                                       FontWeight="Medium"/>
                            <TextBlock x:Name="AccountEmail"
                                       Text="git config user"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="11"/>
                        </StackPanel>

                        <!-- Switch account button -->
                        <Button Grid.Column="2"
                                Content="⇅"
                                Style="{StaticResource IconButtonStyle}"
                                ToolTip="Switch account"
                                Click="SwitchAccount_Click"/>
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <Border Grid.Column="1" Grid.Row="0"
        Background="{DynamicResource AppBgBrush}">
            <ContentControl x:Name="MainContent"/>
        </Border>

        <!-- ===== COMMAND BAR ===== -->
        <Border Grid.Column="1" Grid.Row="1"
                Background="{DynamicResource AccentBlueBrush}"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="$"
                           Foreground="White"
                           FontFamily="Consolas"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBlock Grid.Column="1"
                           x:Name="CommandPreviewText"
                           Text="git status"
                           Foreground="White"
                           FontFamily="Consolas"
                           FontSize="13"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           x:Name="CommandExplainText"
                           Text="shows current repo status"
                           Foreground="#BDD9F2"
                           FontSize="11"
                           VerticalAlignment="Center"
                           FontStyle="Italic"/>
            </Grid>
        </Border>

        <!-- ===== TERMINAL PANEL ===== -->
        <Border Grid.Column="1" Grid.Row="2"
        Background="{DynamicResource TerminalBgBrush}"
        BorderBrush="{DynamicResource TerminalBorderBrush}"
        BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="TERMINAL"
                           Foreground="{DynamicResource TerminalMutedBrush}"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Margin="12,6"/>
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TerminalOutput"
                               Foreground="{DynamicResource TerminalTextBrush}"
                               FontFamily="Consolas"
                               FontSize="12"
                               Margin="12,0,12,12"
                               TextWrapping="Wrap"
                               Text="$ Ready"/>
                </ScrollViewer>
            </Grid>
        </Border>

    </Grid>
</Window>