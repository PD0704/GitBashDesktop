<UserControl x:Class="GitBashDesktop.Views.BranchesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:GitBashDesktop.Helpers">
    <UserControl.Resources>
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>
    <Grid Margin="16" x:Name="Root">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Branches"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="16" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <Border Background="{DynamicResource AccentBlueBrush}"
                    CornerRadius="10" Margin="10,0,0,0" Padding="8,3">
                <TextBlock Text="{Binding CurrentBranch}"
                           Foreground="White" FontSize="11"/>
            </Border>
            <Button Content="↻ Refresh"
                    Command="{Binding LoadBranchesCommand}"
                    Margin="12,0,0,0" Padding="10,4" FontSize="11"
                    Cursor="Hand"
                    Background="{DynamicResource SidebarBgBrush}"
                    Foreground="{DynamicResource TextMutedBrush}"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="1"/>
        </StackPanel>

        <!-- Push / Pull / Fetch -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="⬆ Push"
                    Command="{Binding PushCommand}"
                    Padding="14,7" Margin="0,0,8,0" FontSize="12"
                    Cursor="Hand"
                    Background="{DynamicResource AccentBlueBrush}"
                    Foreground="White" BorderThickness="0"/>
            <Button Content="⬇ Pull"
                    Command="{Binding PullCommand}"
                    Padding="14,7" Margin="0,0,8,0" FontSize="12"
                    Cursor="Hand"
                    Background="{DynamicResource SidebarBgBrush}"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="1"/>
            <Button Content="⟳ Fetch"
                    Command="{Binding FetchCommand}"
                    Padding="14,7" Margin="0,0,24,0" FontSize="12"
                    Cursor="Hand"
                    Background="{DynamicResource SidebarBgBrush}"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="1"/>
            <TextBox Text="{Binding NewBranchName, UpdateSourceTrigger=PropertyChanged}"
                     Width="180" Padding="8,6" FontSize="12"
                     Background="{DynamicResource SidebarBgBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource SidebarBorderBrush}"
                     CaretBrush="{DynamicResource TextPrimaryBrush}"/>
            <Button Content="+ New Branch"
                    Command="{Binding CreateBranchCommand}"
                    Padding="14,7" Margin="8,0,0,0" FontSize="12"
                    Cursor="Hand"
                    Background="#1D9E75"
                    Foreground="White" BorderThickness="0"/>
        </StackPanel>

        <!-- Local branches -->
        <Border Grid.Row="2" Margin="0,0,0,8"
                Background="{DynamicResource SidebarBgBrush}"
                BorderBrush="{DynamicResource SidebarBorderBrush}"
                BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="12,8"
                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Local branches"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="12" FontWeight="SemiBold"/>
                        <Border Background="#3D3D3D" CornerRadius="8"
                                Margin="8,0,0,0" Padding="6,1">
                            <TextBlock Text="{Binding LocalBranches.Count}"
                                       Foreground="#CCCCCC" FontSize="10"/>
                        </Border>
                    </StackPanel>
                </Border>
                <ListView Grid.Row="1"
                          ItemsSource="{Binding LocalBranches}"
                          Background="Transparent"
                          BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding CurrentIndicator}"
                                           Foreground="#007ACC"
                                           FontSize="10"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Name}"
                                           Foreground="{Binding NameColor}"
                                           FontSize="13"
                                           FontFamily="Consolas"
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <Button Content="switch"
                                            Command="{Binding DataContext.SwitchBranchCommand,
                                                ElementName=Root}"
                                            CommandParameter="{Binding}"
                                            Padding="8,3" Margin="0,0,6,0"
                                            FontSize="11" Cursor="Hand"
                                            Background="{DynamicResource AccentBlueBrush}"
                                            Foreground="White" BorderThickness="0"/>
                                    <Button Content="merge"
                                            Command="{Binding DataContext.MergeCommand,
                                                ElementName=Root}"
                                            CommandParameter="{Binding}"
                                            Padding="8,3" Margin="0,0,6,0"
                                            FontSize="11" Cursor="Hand"
                                            Background="#76448A"
                                            Foreground="White" BorderThickness="0"
                                            Visibility="{Binding IsCurrent,
                                                Converter={StaticResource InverseBoolToVisibility}}"/>
                                    <Button Content="delete"
                                            Command="{Binding DataContext.DeleteBranchCommand,
                                                ElementName=Root}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding DeleteVisible}"
                                            Padding="8,3" FontSize="11"
                                            Cursor="Hand"
                                            Background="#A32D2D"
                                            Foreground="White" BorderThickness="0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="12,2"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </Border>

        <!-- Remote branches -->
        <Border Grid.Row="3"
                Background="{DynamicResource SidebarBgBrush}"
                BorderBrush="{DynamicResource SidebarBorderBrush}"
                BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="12,8"
                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Remote branches"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="12" FontWeight="SemiBold"/>
                        <Border Background="#3D3D3D" CornerRadius="8"
                                Margin="8,0,0,0" Padding="6,1">
                            <TextBlock Text="{Binding RemoteBranches.Count}"
                                       Foreground="#CCCCCC" FontSize="10"/>
                        </Border>
                    </StackPanel>
                </Border>
                <ListView Grid.Row="1"
                          ItemsSource="{Binding RemoteBranches}"
                          Background="Transparent"
                          BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding CurrentIndicator}"
                                           Foreground="#007ACC"
                                           FontSize="10"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Name}"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="13"
                                           FontFamily="Consolas"
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <Button Content="checkout"
                                            Command="{Binding DataContext.CheckoutRemoteCommand,
                                                ElementName=Root}"
                                            CommandParameter="{Binding}"
                                            Padding="8,3" Margin="0,0,6,0"
                                            FontSize="11" Cursor="Hand"
                                            Background="#1D9E75"
                                            Foreground="White" BorderThickness="0"/>
                                    <Button Content="delete"
                                            Command="{Binding DataContext.DeleteRemoteCommand,
                                                ElementName=Root}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding DeleteVisible}"
                                            Padding="8,3" FontSize="11"
                                            Cursor="Hand"
                                            Background="#A32D2D"
                                            Foreground="White" BorderThickness="0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="12,2"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</UserControl>