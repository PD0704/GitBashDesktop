<UserControl x:Class="GitBashDesktop.Views.CommitHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:GitBashDesktop.Helpers">
    <UserControl.Resources>
        <helpers:DiffLineColorConverter x:Key="DiffLineColorConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <!-- ===== LEFT: commit list ===== -->
        <Grid Grid.Column="0" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal"
                        Margin="0,0,0,12">
                <TextBlock Text="Commit History"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Border Background="#3D3D3D" CornerRadius="8"
                        Margin="10,0,0,0" Padding="6,1">
                    <TextBlock Text="{Binding FilteredCommits.Count}"
                               Foreground="#CCCCCC" FontSize="10"/>
                </Border>
                <Button Content="↻ Refresh"
                        Command="{Binding LoadCommitsCommand}"
                        Margin="12,0,0,0" Padding="10,4" FontSize="11"
                        Cursor="Hand"
                        Background="{DynamicResource SidebarBgBrush}"
                        Foreground="{DynamicResource TextMutedBrush}"
                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                        BorderThickness="1"/>
            </StackPanel>

            <!-- Search + Branch filter -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Grid Grid.Column="0" Margin="0,0,8,0">
                    <TextBox Text="{Binding FilterText,
                                 UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,7" FontSize="12"
                             Background="{DynamicResource SidebarBgBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource SidebarBorderBrush}"
                             CaretBrush="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Search commits..."
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12" Margin="12,0,0,0"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FilterText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding FilterText}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Branch filter -->
                <ComboBox Grid.Column="1"
          ItemsSource="{Binding Branches}"
          SelectedItem="{Binding SelectedBranch}"
          Style="{StaticResource DarkComboBoxStyle}"/>
            </Grid>

            <!-- Commit list -->
            <Border Grid.Row="2"
                    Background="{DynamicResource SidebarBgBrush}"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="1" CornerRadius="6">
                <ListView x:Name="CommitList"
                          ItemsSource="{Binding FilteredCommits}"
                          Background="Transparent"
                          BorderThickness="0"
                          HorizontalContentAlignment="Stretch"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,10"
                                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SelectCommitCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Avatar -->
                                    <Border Grid.Column="0"
                                            Width="34" Height="34"
                                            CornerRadius="17"
                                            Background="{DynamicResource AccentBlueBrush}"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="{Binding AvatarInitials}"
                                                   Foreground="White"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Message + author -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ShortMessage}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="13"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="{Binding Author}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       FontSize="11"/>
                                            <TextBlock Text=" · "
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       FontSize="11"/>
                                            <TextBlock Text="{Binding Date}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Short hash -->
                                    <Border Grid.Column="2"
                                            Background="{DynamicResource AppBgBrush}"
                                            CornerRadius="4" Padding="6,3"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ShortHash}"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   FontFamily="Consolas" FontSize="11"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background"
                                            Value="{DynamicResource SidebarHoverBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Border>
        </Grid>

        <!-- ===== RIGHT: commit detail ===== -->
        <Border Grid.Column="1" Margin="0,16,16,16"
        Background="{DynamicResource SidebarBgBrush}"
        BorderBrush="{DynamicResource SidebarBorderBrush}"
        BorderThickness="1" CornerRadius="6">

            <Grid>
                <!-- No selection -->
                <TextBlock Text="Click a commit to see details"
                   Foreground="{DynamicResource TextMutedBrush}"
                   FontSize="13"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="{Binding SelectedCommit,
                       Converter={StaticResource InverseBoolToVisibility}}"/>

                <!-- Detail panel -->
                <Grid Visibility="{Binding SelectedCommit,
                  Converter={StaticResource NullToVisibility}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Commit info -->
                    <Border Grid.Row="0" Padding="14,12"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedCommit.Message}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="13" FontWeight="SemiBold"
                               TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="{Binding SelectedCommit.Author}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11"/>
                                <TextBlock Text=" · "
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11"/>
                                <TextBlock Text="{Binding SelectedCommit.Date}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11"/>
                            </StackPanel>

                            <!-- Hash + copy buttons -->
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Border Background="{DynamicResource AppBgBrush}"
                                CornerRadius="4" Padding="6,3">
                                    <TextBlock Text="{Binding SelectedCommit.ShortHash}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontFamily="Consolas" FontSize="11"/>
                                </Border>
                                <Button Content="Copy short"
                                Command="{Binding CopyShortHashCommand}"
                                Margin="6,0,0,0" Padding="6,3" FontSize="10"
                                Cursor="Hand"
                                Background="{DynamicResource SidebarBgBrush}"
                                Foreground="{DynamicResource TextMutedBrush}"
                                BorderBrush="{DynamicResource SidebarBorderBrush}"
                                BorderThickness="1"/>
                                <Button Content="Copy full"
                                Command="{Binding CopyFullHashCommand}"
                                Margin="4,0,0,0" Padding="6,3" FontSize="10"
                                Cursor="Hand"
                                Background="{DynamicResource SidebarBgBrush}"
                                Foreground="{DynamicResource TextMutedBrush}"
                                BorderBrush="{DynamicResource SidebarBorderBrush}"
                                BorderThickness="1"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Files changed / diff toggle -->
                    <Border Grid.Row="1" Padding="14,8"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Files changed"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                            <Border Background="#3D3D3D" CornerRadius="8"
                            Margin="8,0,0,0" Padding="6,1">
                                <TextBlock Text="{Binding ChangedFiles.Count}"
                                   Foreground="#CCCCCC" FontSize="10"/>
                            </Border>
                            <Button Content="← Back to files"
                            Command="{Binding ShowFileDiffCommand}"
                            CommandParameter=""
                            Margin="12,0,0,0" Padding="6,3" FontSize="10"
                            Cursor="Hand"
                            Background="{DynamicResource SidebarBgBrush}"
                            Foreground="{DynamicResource TextMutedBrush}"
                            BorderBrush="{DynamicResource SidebarBorderBrush}"
                            BorderThickness="1"
                            Visibility="{Binding ShowDiff,
                                Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Files list / diff view -->
                    <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <!-- Files list -->
                            <ItemsControl ItemsSource="{Binding ChangedFiles}"
                                  Margin="0,4"
                                  Visibility="{Binding ShowDiff,
                                      Converter={StaticResource InverseBoolToVisibility}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="14,7"
                                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Cursor="Hand">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.ShowFileDiffCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"/>
                                            </Border.InputBindings>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="·"
                                                   Foreground="{DynamicResource AccentBlueBrush}"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontFamily="Consolas" FontSize="12"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Diff view -->
                            <ItemsControl Margin="0,4"
                                  Visibility="{Binding ShowDiff,
                                      Converter={StaticResource BoolToVisibility}}"
                                  ItemsSource="{Binding DiffOutput,
                                      Converter={StaticResource StringToLinesConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding
                                            Converter={StaticResource DiffLineColorConverter},
                                            ConverterParameter=bg}"
                                        Padding="8,2">
                                            <TextBlock Text="{Binding}"
                                               FontFamily="Consolas" FontSize="11"
                                               TextWrapping="NoWrap"
                                               Foreground="{Binding
                                                   Converter={StaticResource DiffLineColorConverter},
                                                   ConverterParameter=fg}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>

                    <!-- Actions: revert + create branch -->
                    <Border Grid.Row="3" Padding="14,10"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="0,1,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBox Text="{Binding NewBranchName,
                                     UpdateSourceTrigger=PropertyChanged}"
                                 Width="150" Padding="6,5" FontSize="11"
                                 Background="{DynamicResource AppBgBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource SidebarBorderBrush}"
                                 CaretBrush="{DynamicResource TextPrimaryBrush}"/>
                                <Button Content="Branch here"
                                Command="{Binding CreateBranchFromCommitCommand}"
                                Margin="6,0,0,0" Padding="8,5" FontSize="11"
                                Cursor="Hand"
                                Background="#1D9E75"
                                Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                            <Button Content="⟲ Revert this commit"
                            Command="{Binding RevertCommitCommand}"
                            HorizontalAlignment="Stretch"
                            Padding="0,7" FontSize="12" Cursor="Hand"
                            Background="#A32D2D"
                            Foreground="White" BorderThickness="0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>