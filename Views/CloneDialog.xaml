<Window x:Class="GitBashDesktop.Views.CloneDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clone Repository"
        Height="200" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBgBrush}">
    <StackPanel Margin="20">
        <TextBlock Text="Repository URL"
                   Foreground="{DynamicResource TextMutedBrush}"
                   FontSize="12" Margin="0,0,0,6"/>
        <TextBox x:Name="UrlBox"
                 FontSize="13"
                 Padding="8"
                 Background="{DynamicResource SidebarBgBrush}"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 BorderBrush="{DynamicResource SidebarBorderBrush}"
                 CaretBrush="{DynamicResource TextPrimaryBrush}"/>
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Cancel" Width="80" Margin="0,0,8,0"
                    Click="Cancel_Click"
                    Padding="0,7"
                    Background="{DynamicResource SidebarBgBrush}"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"/>
            <Button Content="Clone" Width="80"
                    Click="Clone_Click"
                    Padding="0,7"
                    Background="{DynamicResource AccentBlueBrush}"
                    Foreground="White"
                    BorderThickness="0"/>
        </StackPanel>
    </StackPanel>
</Window>