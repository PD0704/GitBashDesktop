<UserControl x:Class="GitBashDesktop.Views.MergeConflictsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:GitBashDesktop.Helpers">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <helpers:NullToVisibilityConverter x:Key="NullToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== LEFT: file list ===== -->
        <Grid Grid.Column="0" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Merge Conflicts"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="16" FontWeight="SemiBold"/>
                    <Button Content="↻"
                            Command="{Binding LoadConflictsCommand}"
                            Margin="10,0,0,0" Padding="6,4" FontSize="11"
                            Cursor="Hand"
                            Background="{DynamicResource SidebarBgBrush}"
                            Foreground="{DynamicResource TextMutedBrush}"
                            BorderBrush="{DynamicResource SidebarBorderBrush}"
                            BorderThickness="1"/>
                </StackPanel>
                <TextBlock Text="{Binding MergeStatus}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="11" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- No conflicts -->
            <TextBlock Grid.Row="1"
                       Text="No conflicts found.&#x0a;Start a merge to see conflicts here."
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="12" TextWrapping="Wrap"
                       Visibility="{Binding HasMerge,
                           Converter={StaticResource InverseBoolToVisibility}}"/>

            <!-- Conflict files -->
            <Border Grid.Row="1"
                    Background="{DynamicResource SidebarBgBrush}"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="1" CornerRadius="6"
                    Visibility="{Binding HasMerge,
                        Converter={StaticResource BoolToVisibility}}">
                <ListView ItemsSource="{Binding ConflictFiles}"
          Background="Transparent"
          BorderThickness="0"
          HorizontalContentAlignment="Stretch"
          SelectionChanged="ConflictFiles_SelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,10"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Cursor="Hand">
                                <StackPanel>
                                    <TextBlock Text="{Binding FileName}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="12" FontWeight="SemiBold"
                               FontFamily="Consolas"/>
                                    <StackPanel Orientation="Horizontal"
                                Margin="0,4,0,0">
                                        <Border CornerRadius="8" Padding="6,2"
                                Margin="0,0,6,0">
                                            <Border.Background>
                                                <SolidColorBrush Color="#E2B714"
                                                 Opacity="0.2"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding StatusText}"
                                       FontSize="10"
                                       Foreground="{Binding StatusColor}"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background"
                            Value="{DynamicResource SidebarHoverBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Border>

            <!-- Abort merge button -->
            <Button Grid.Row="2"
                    Content="✕ Abort Merge"
                    Command="{Binding AbortMergeCommand}"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Stretch"
                    Padding="0,8" FontSize="12" Cursor="Hand"
                    Background="#A32D2D"
                    Foreground="White" BorderThickness="0"
                    Visibility="{Binding HasMerge,
                        Converter={StaticResource BoolToVisibility}}"/>
        </Grid>

        <!-- ===== RIGHT: conflict resolver ===== -->
        <Grid Grid.Column="1" Margin="0,16,16,16">

            <!-- No file selected -->
            <TextBlock Text="Select a conflicted file to resolve it"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="{Binding SelectedFile,
                           Converter={StaticResource InverseBoolToVisibility}}"/>

            <!-- Resolver -->
            <Grid Visibility="{Binding SelectedFile,
          Converter={StaticResource NullToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- File header — always visible -->
                <Border Grid.Row="0" Padding="0,0,0,12"
            BorderBrush="{DynamicResource SidebarBorderBrush}"
            BorderThickness="0,0,0,1" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding SelectedFile.FileName}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="14" FontWeight="SemiBold"
                       FontFamily="Consolas"
                       VerticalAlignment="Center"/>
                        <Border CornerRadius="8" Padding="8,3" Margin="10,0,0,0"
                    Background="#2A2A2A">
                            <TextBlock Text="{Binding SelectedFile.StatusText}"
                           Foreground="{Binding SelectedFile.StatusColor}"
                           FontSize="11"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- DELETE/MODIFY CONFLICT — spans rows 1,2,3 -->
                <Border Grid.Row="1" Grid.RowSpan="3"
            Padding="24"
            Visibility="{Binding SelectedFile.IsDeleteModifyConflict,
                Converter={StaticResource BoolToVisibility}}">
                    <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                        <TextBlock Text="⚠ Delete / Modify Conflict"
                       Foreground="#E2B714"
                       FontSize="16" FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>
                        <TextBlock Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="12" TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,0,0,24">
                <Run Text="This file was "/>
                <Run Text="deleted" Foreground="#F47067" FontWeight="SemiBold"/>
                <Run Text=" in one branch but "/>
                <Run Text="modified" Foreground="#4EC994" FontWeight="SemiBold"/>
                <Run Text=" in the other."/>
                <LineBreak/>
                <Run Text="Choose what to do with it:"/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                            <Button Content="✓ Keep the file"
                        Command="{Binding KeepFileCommand}"
                        Padding="20,10" Margin="0,0,12,0"
                        FontSize="13" Cursor="Hand"
                        Background="#1D9E75"
                        Foreground="White" BorderThickness="0"/>
                            <Button Content="✕ Delete the file"
                        Command="{Binding DeleteFileCommand}"
                        Padding="20,10" FontSize="13" Cursor="Hand"
                        Background="#A32D2D"
                        Foreground="White" BorderThickness="0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- NORMAL CONFLICT: block pills — hidden for delete/modify -->
                <Border Grid.Row="1" Margin="0,0,0,12"
            Background="{DynamicResource SidebarBgBrush}"
            BorderBrush="{DynamicResource SidebarBorderBrush}"
            BorderThickness="1" CornerRadius="6"
            MaxHeight="80"
            Visibility="{Binding SelectedFile.IsDeleteModifyConflict,
                Converter={StaticResource InverseBoolToVisibility}}">
                    <ListView ItemsSource="{Binding SelectedFile.Blocks}"
                  SelectedItem="{Binding SelectedBlock}"
                  Background="Transparent"
                  BorderThickness="0"
                  HorizontalContentAlignment="Stretch"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,6" Margin="4,4"
                            CornerRadius="4" Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"
                                        Value="{DynamicResource AppBgBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsResolved}"
                                                 Value="True">
                                                    <Setter Property="Background"
                                                Value="#1D4731"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding DataContext.SelectBlockCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <TextBlock Text="{Binding DisplayIndex}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Border>

                <!-- NORMAL CONFLICT: side by side — hidden for delete/modify -->
                <Grid Grid.Row="2"
          Visibility="{Binding SelectedFile.IsDeleteModifyConflict,
              Converter={StaticResource InverseBoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Ours -->
                    <Border Grid.Column="0"
                Background="{DynamicResource SidebarBgBrush}"
                BorderBrush="#1D9E75"
                BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Padding="12,8"
                        Background="#1D4731"
                        CornerRadius="6,6,0,0">
                                <TextBlock Text="◀ Ours (current branch)"
                               Foreground="#4EC994"
                               FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                            <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding SelectedBlock.OursText}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontFamily="Consolas" FontSize="12"
                               Padding="12" TextWrapping="NoWrap"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Theirs -->
                    <Border Grid.Column="2"
                Background="{DynamicResource SidebarBgBrush}"
                BorderBrush="#185FA5"
                BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Padding="12,8"
                        Background="#0C2A4A"
                        CornerRadius="6,6,0,0">
                                <TextBlock Text="▶ Theirs (incoming)"
                               Foreground="#378ADD"
                               FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                            <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding SelectedBlock.TheirsText}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontFamily="Consolas" FontSize="12"
                               Padding="12" TextWrapping="NoWrap"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- No block selected placeholder -->
                    <TextBlock Grid.Column="0" Grid.ColumnSpan="3"
                   Text="Select a conflict block above"
                   Foreground="{DynamicResource TextMutedBrush}"
                   FontSize="13"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="{Binding SelectedBlock,
                       Converter={StaticResource InverseBoolToVisibility}}"/>
                </Grid>

                <!-- NORMAL CONFLICT: action buttons — hidden for delete/modify -->
                <Border Grid.Row="3" Padding="0,12,0,0"
            BorderBrush="{DynamicResource SidebarBorderBrush}"
            BorderThickness="0,1,0,0" Margin="0,12,0,0"
            Visibility="{Binding SelectedFile.IsDeleteModifyConflict,
                Converter={StaticResource InverseBoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                    Content="◀ Keep Ours"
                    Command="{Binding ResolveOursCommand}"
                    Margin="0,0,6,0" Padding="0,8"
                    FontSize="12" Cursor="Hand"
                    Background="#1D9E75"
                    Foreground="White" BorderThickness="0"/>
                        <Button Grid.Column="1"
                    Content="▶ Keep Theirs"
                    Command="{Binding ResolveTheirsCommand}"
                    Margin="0,0,6,0" Padding="0,8"
                    FontSize="12" Cursor="Hand"
                    Background="#185FA5"
                    Foreground="White" BorderThickness="0"/>
                        <Button Grid.Column="2"
                    Content="⊕ Keep Both"
                    Command="{Binding ResolveBothCommand}"
                    Padding="0,8" FontSize="12" Cursor="Hand"
                    Background="#76448A"
                    Foreground="White" BorderThickness="0"/>
                        <Button Grid.Column="4"
                    Content="✓ Apply Resolution"
                    Command="{Binding ApplyResolutionCommand}"
                    Padding="0,8" FontSize="12" Cursor="Hand"
                    Background="{DynamicResource AccentBlueBrush}"
                    Foreground="White" BorderThickness="0"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>