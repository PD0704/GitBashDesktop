<UserControl x:Class="GitBashDesktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:GitBashDesktop.Helpers">
    <UserControl.Resources>
        <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" MaxWidth="600">

            <!-- Header -->
            <TextBlock Text="Settings"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="20" FontWeight="SemiBold"
                       Margin="0,0,0,24"/>

            <!-- ===== APPEARANCE ===== -->
            <TextBlock Text="APPEARANCE"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="11" FontWeight="SemiBold"
                       Margin="0,0,0,12"/>

            <Border Background="{DynamicResource SidebarBgBrush}"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Margin="0,0,0,24">
                <StackPanel>

                    <!-- Dark theme -->
                    <Border Padding="16,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Dark theme"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="13"/>
                                <TextBlock Text="Switch between dark and light mode"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      IsChecked="{Binding IsDarkTheme}"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border BorderBrush="{DynamicResource SidebarBorderBrush}"
                            BorderThickness="0,1,0,0"/>

                    <!-- Expert mode -->
                    <Border Padding="16,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Expert mode"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="13"/>
                                <TextBlock Text="Hide command explanations and tooltips for a compact UI"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="11" Margin="0,2,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      IsChecked="{Binding IsExpertMode}"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                </StackPanel>
            </Border>

            <!-- ===== BEHAVIOUR ===== -->
            <TextBlock Text="BEHAVIOUR"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="11" FontWeight="SemiBold"
                       Margin="0,0,0,12"/>

            <Border Background="{DynamicResource SidebarBgBrush}"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Margin="0,0,0,24">
                <Border Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Auto-open last repository"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="13"/>
                            <TextBlock Text="Automatically open the last used repo when the app starts"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="11" Margin="0,2,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding AutoOpenLastRepo}"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Border>

            <!-- ===== GIT IDENTITY ===== -->
            <TextBlock Text="GIT IDENTITY"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="11" FontWeight="SemiBold"
                       Margin="0,0,0,12"/>

            <Border Background="{DynamicResource SidebarBgBrush}"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Margin="0,0,0,16">
                <Border Padding="16,14">
                    <StackPanel>

                        <!-- Name -->
                        <TextBlock Text="Name"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding GitUserName,
                                     UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8" FontSize="13"
                                 Background="{DynamicResource AppBgBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource SidebarBorderBrush}"
                                 CaretBrush="{DynamicResource TextPrimaryBrush}"
                                 Margin="0,0,0,14"/>

                        <!-- Email -->
                        <TextBlock Text="Email"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding GitUserEmail,
                                     UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8" FontSize="13"
                                 Background="{DynamicResource AppBgBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource SidebarBorderBrush}"
                                 CaretBrush="{DynamicResource TextPrimaryBrush}"
                                 Margin="0,0,0,16"/>

                        <Button Content="Save git config"
                                Command="{Binding SaveGitConfigCommand}"
                                HorizontalAlignment="Left"
                                Padding="16,8" FontSize="12" Cursor="Hand"
                                Background="{DynamicResource AccentBlueBrush}"
                                Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Status message -->
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#1D9E75"
                       FontSize="12" Margin="0,0,0,24"
                       Visibility="{Binding StatusMessage,
                           Converter={StaticResource StringToVisibilityConverter}}"/>

            <!-- Reset -->
            <Button Content="Reset to defaults"
                    Command="{Binding ResetDefaultsCommand}"
                    HorizontalAlignment="Left"
                    Padding="14,7" FontSize="12" Cursor="Hand"
                    Background="{DynamicResource SidebarBgBrush}"
                    Foreground="{DynamicResource TextMutedBrush}"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="1"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>