<UserControl x:Class="GitBashDesktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:GitBashDesktop.Helpers"
             xmlns:vm="clr-namespace:GitBashDesktop.ViewModels">
    <UserControl.Resources>
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- No repo open state -->
        <StackPanel Grid.Row="0" Grid.RowSpan="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding HasRepo,
                        Converter={StaticResource  InverseBoolToVisibility}}">
            <TextBlock Text="No repository open"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="18" FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Open a local folder or clone from a URL"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="12" Margin="0,6,0,24"
                       HorizontalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Open Repository"
                        Command="{Binding OpenRepoCommand}"
                        Padding="16,9" Margin="0,0,10,0"
                        FontSize="13" Cursor="Hand"
                        Background="{DynamicResource AccentBlueBrush}"
                        Foreground="White" BorderThickness="0"/>
                <Button Content="Clone Repository"
                        Command="{Binding CloneRepoCommand}"
                        Padding="16,9" FontSize="13" Cursor="Hand"
                        Background="{DynamicResource SidebarBgBrush}"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                        BorderThickness="1"/>
            </StackPanel>
        </StackPanel>

        <!-- Repo open state -->
        <Grid Visibility="{Binding HasRepo,
                  Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Left: file lists -->
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Repo header -->
                <StackPanel Grid.Row="0" Orientation="Horizontal"
                            Margin="0,0,0,16">
                    <TextBlock Text="{Binding RepoName}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Border Background="{DynamicResource AccentBlueBrush}"
                            CornerRadius="10" Margin="10,0,0,0"
                            Padding="8,3">
                        <TextBlock Text="{Binding CurrentBranch}"
                                   Foreground="White" FontSize="11"/>
                    </Border>
                    <Button Content="↻ Refresh"
                            Command="{Binding RefreshCommand}"
                            Margin="12,0,0,0" Padding="10,4"
                            FontSize="11" Cursor="Hand"
                            Background="{DynamicResource SidebarBgBrush}"
                            Foreground="{DynamicResource TextMutedBrush}"
                            BorderBrush="{DynamicResource SidebarBorderBrush}"
                            BorderThickness="1"/>
                </StackPanel>

                <!-- Unstaged files -->
                <Border Grid.Row="1" Margin="0,0,0,8"
                        Background="{DynamicResource SidebarBgBrush}"
                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                        BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Padding="12,8"
                                BorderBrush="{DynamicResource SidebarBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Unstaged changes"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="12" FontWeight="SemiBold"/>
                                <Border Background="#3D3D3D" CornerRadius="8"
                                        Margin="8,0,0,0" Padding="6,1">
                                    <TextBlock Text="{Binding ChangedFiles.Count}"
                                               Foreground="#CCCCCC" FontSize="10"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <ListView Grid.Row="1"
                                  ItemsSource="{Binding ChangedFiles}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  MaxHeight="180">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSelected}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,8,0"/>
                                        <Border Grid.Column="1"
                                                Background="{Binding StatusColor}"
                                                CornerRadius="3" Padding="4,1"
                                                Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Status}"
                                                       Foreground="#0C0C0C"
                                                       FontSize="10"/>
                                        </Border>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding FileName}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="12"
                                                   FontFamily="Consolas"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="12,2"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                        <Border Grid.Row="2" Padding="8,6"
                                BorderBrush="{DynamicResource SidebarBorderBrush}"
                                BorderThickness="0,1,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Stage Selected"
                                        Command="{Binding StageSelectedCommand}"
                                        Padding="10,5" Margin="0,0,6,0"
                                        FontSize="11" Cursor="Hand"
                                        Background="{DynamicResource AccentBlueBrush}"
                                        Foreground="White" BorderThickness="0"/>
                                <Button Content="Stage All"
                                        Command="{Binding StageAllCommand}"
                                        Padding="10,5" FontSize="11" Cursor="Hand"
                                        Background="{DynamicResource SidebarBgBrush}"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                                        BorderThickness="1"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Staged files -->
                <Border Grid.Row="2"
                        Background="{DynamicResource SidebarBgBrush}"
                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                        BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Padding="12,8"
                                BorderBrush="{DynamicResource SidebarBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Staged for commit"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="12" FontWeight="SemiBold"/>
                                <Border Background="#1D9E75" CornerRadius="8"
                                        Margin="8,0,0,0" Padding="6,1">
                                    <TextBlock Text="{Binding StagedFiles.Count}"
                                               Foreground="White" FontSize="10"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <ListView Grid.Row="1"
                                  ItemsSource="{Binding StagedFiles}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  MaxHeight="180">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Background="{Binding StatusColor}"
                                                CornerRadius="3" Padding="4,1"
                                                Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Status}"
                                                       Foreground="#0C0C0C"
                                                       FontSize="10"/>
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding FileName}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="12"
                                                   FontFamily="Consolas"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="2"
                                                Content="unstage"
                                                Command="{Binding DataContext.UnstageCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Padding="6,2" FontSize="10"
                                                Cursor="Hand"
                                                Background="Transparent"
                                                Foreground="{DynamicResource TextMutedBrush}"
                                                BorderThickness="0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="12,2"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <!-- Right: commit panel -->
            <Border Grid.Column="1" Margin="0,16,16,16"
                    Background="{DynamicResource SidebarBgBrush}"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="12,10"
                            BorderBrush="{DynamicResource SidebarBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="Commit"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="13" FontWeight="SemiBold"/>
                    </Border>

                    <TextBox Grid.Row="1"
                             Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Padding="12"
                             FontSize="13"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"
                             CaretBrush="{DynamicResource TextPrimaryBrush}"
                             VerticalScrollBarVisibility="Auto">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None"
                                                             AlignmentX="Left"
                                                             AlignmentY="Top">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="Commit message..."
                                                                   Foreground="#555555"
                                                                   FontSize="13"
                                                                   Margin="12,12,0,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <Border Grid.Row="2" Padding="12,10"
                            BorderBrush="{DynamicResource SidebarBorderBrush}"
                            BorderThickness="0,1,0,0">
                        <Button Content="Commit changes"
                                Command="{Binding CommitCommand}"
                                HorizontalAlignment="Stretch"
                                Padding="0,9" FontSize="13" Cursor="Hand"
                                Background="{DynamicResource AccentBlueBrush}"
                                Foreground="White" BorderThickness="0"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>